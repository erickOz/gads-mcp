# ─── Google Ads API credentials ─────────────────────────────────────────────
# Option A (recommended for production): individual environment variables
# The server will call GoogleAdsClient.load_from_env() when these are set.
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Option B (local development): path to google-ads.yaml file
# GOOGLE_ADS_CREDENTIALS=/path/to/google-ads.yaml

# ─── MCP server authentication ───────────────────────────────────────────────
# Enable Google OAuth2 login for the MCP server itself so Claude and other
# clients authenticate before calling any tool.
# Create an OAuth 2.0 Web Application credential in Google Cloud Console,
# then add <BASE_URL>/oauth/callback as an authorised redirect URI.
FASTMCP_SERVER_BASE_URL=https://your-service-url.run.app
FASTMCP_SERVER_AUTH_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
FASTMCP_SERVER_AUTH_GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# ─── Server settings ─────────────────────────────────────────────────────────
# PORT is set automatically by Cloud Run; override here for local Docker use.
# PORT=8080

# ─── docker-compose only ─────────────────────────────────────────────────────
# Path to your local google-ads.yaml to mount into the container (Option B)
# GOOGLE_ADS_CREDENTIALS_FILE=./google-ads.yaml
# MCP_PORT=8000
